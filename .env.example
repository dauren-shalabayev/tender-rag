# CORS: * или список через запятую, например https://app.example.com,http://localhost:5173
# CORS_ORIGINS=*

DATABASE_URL=postgresql://rag:rag@localhost:5437/rag
EMBEDDING_MODEL=intfloat/multilingual-e5-small
# для ingest_local внутри контейнера:
# FILES_DIR=/files

# Разбор текста через OpenAI (POST /v1/match/analyze):
# Скопируй этот файл в .env и вставь ключ ТОЛЬКО в .env (он в .gitignore).
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Профиль компании по умолчанию (если в POST не передали profile):
# COMPANY_PROFILE=Мы оказываем ...
# или длинный текст из файла (в Docker по умолчанию смотрит files/company_profile.txt):
# COMPANY_PROFILE_FILE=/files/company_profile.txt
